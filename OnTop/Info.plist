<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>OnTop</string>
    <key>CFBundleDisplayName</key>
    <string>OnTop</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <!-- Hides the app from the Dock entirely -->
    <key>LSUIElement</key>
    <true/>

    <!-- Minimum macOS — required for SMAppService (launch at login) -->
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>

    <!-- Accessibility usage description shown in System Settings -->
    <key>NSAccessibilityUsageDescription</key>
    <string>OnTop needs Accessibility access to detect which window is in front so it can pin it above all others.</string>

    <!-- Screen Recording usage description — required to capture window pixels for the overlay -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>OnTop needs Screen Recording access to display a live preview of your pinned window above all others.</string>
</dict>
</plist>
